{
  "schema_version": "x07.device.profile@0.1.0",
  "id": "device_desktop_dev",
  "v": 1,
  "target": "desktop",
  "identity": {
    "display_name": "x07 CrewOps (Desktop Dev)",
    "app_id": "io.x07.crewops.desktop.dev"
  },
  "version": {
    "version": "0.1.0",
    "build": 1
  },
  "security": {
    "allow_dynamic_code_loading": false
  },
  "ui": {
    "project": "frontend/x07.json",
    "web_ui_profile_id": "web_ui_debug"
  },
  "backend": {
    "mode": "remote_http",
    "base_url": "http://127.0.0.1:17081",
    "allowed_hosts": [
      "127.0.0.1",
      "localhost"
    ]
  },
  "capabilities": {
    "path": "arch/device/profiles/device_dev.capabilities.json"
  },
  "telemetry_profile": {
    "path": "arch/device/profiles/device_desktop_dev.telemetry.profile.json"
  },
  "desktop": {
    "window": {
      "width": 1200,
      "height": 760,
      "resizable": true
    },
    "package": {
      "kind": "dir"
    }
  },
  "notes": "CrewOps desktop dev runs against the local app serve endpoint on 127.0.0.1:17081."
}
