{
  "schema_version": "x07.device.profile@0.1.0",
  "id": "device_android_dev",
  "v": 1,
  "target": "android",
  "identity": {
    "display_name": "x07 CrewOps (Android Dev)",
    "app_id": "io.x07.crewops.android.dev"
  },
  "version": {
    "version": "0.4.0",
    "build": 1
  },
  "security": {
    "allow_dynamic_code_loading": false
  },
  "ui": {
    "project": "frontend/x07.json",
    "web_ui_profile_id": "web_ui_debug"
  },
  "backend": {
    "mode": "remote_http",
    "base_url": "https://example.invalid",
    "allowed_hosts": ["example.invalid"]
  },
  "capabilities": {
    "path": "arch/device/profiles/device_mobile_dev.capabilities.json"
  },
  "telemetry_profile": {
    "path": "arch/device/profiles/device_android_dev.telemetry.profile.json"
  },
  "android": {
    "application_id": "io.x07.crewops.android.dev",
    "min_sdk": 24,
    "signing_mode": "dev"
  },
  "notes": "CrewOps Android packaging keeps runtime network denied until a real backend base_url and allowlist are configured in this profile; the same M5 reducer is packaged here with camera, import, blob storage, foreground location, and local notifications enabled."
}
